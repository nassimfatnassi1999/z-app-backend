NODE_ENV=production

BACKEND_HOST_PORT=3002
BACKEND_CONTAINER_PORT=3000

POSTGRES_HOST_PORT=55432
POSTGRES_CONTAINER_PORT=5432

POSTGRES_DB=zdb
POSTGRES_USER=z_user
POSTGRES_PASSWORD=change_me_secure_password

DATABASE_URL=postgresql://z_user:change_me_secure_password@z_postgres:5432/zdb

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EMAIL_MODEL=llama-3.3-70b-versatile
GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile
GROQ_VALIDATION_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.35
GROQ_MAX_TOKENS=1200
GROQ_TIMEOUT_MS=30000
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_REPAIR_ATTEMPTS=1

DEEPGRAM_API_KEY=

MAIL_PROVIDER=brevo
MAIL_ENABLED=true

BREVO_API_KEY=
BREVO_FROM_NAME=Z
BREVO_FROM_EMAIL=your_verified_sender@example.com
BREVO_REPLY_TO=

EMAIL_VERIFICATION_CODE_TTL_MINUTES=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_CODE_SECRET=change_me_long_random_secret

PORT=3000
